# DNS tunneling detection rules (defensive)
# Scope: UDP 53 query/response, known suspicious domain patterns, unusual query types

alert udp any any -> any 53 (msg:"DNS_TUNNEL attacker.lab domain pattern"; \
  content:"attacker.lab"; nocase; classtype:policy-violation; sid:1000001; rev:2;)

alert udp any any -> any 53 (msg:"DNS_TUNNEL suspicious TXT query"; \
  byte_test:2,=,16,2,relative; classtype:policy-violation; sid:1000002; rev:2;)

alert udp any any -> any 53 (msg:"DNS_TUNNEL suspicious CNAME query"; \
  byte_test:2,=,5,2,relative; classtype:policy-violation; sid:1000003; rev:2;)

alert udp any any -> any 53 (msg:"DNS_TUNNEL suspicious MX query"; \
  byte_test:2,=,15,2,relative; classtype:policy-violation; sid:1000004; rev:2;)

alert udp any any -> any 53 (msg:"DNS_TUNNEL long DNS payload"; \
  dsize:>200; classtype:policy-violation; sid:1000005; rev:2;)
